{
  "manifest_version": 3,
  "name": "Kainos Task List",
  "version": "0.5.0",
  "description": "A simple task list with optional AI priority suggestions (BYOK via OpenRouter).",
  "action": {
    "default_title": "Kainos Task List",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "host_permissions": ["https://openrouter.ai/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
